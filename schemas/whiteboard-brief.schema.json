{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Structured Feishu Whiteboard Brief",
  "type": "object",
  "additionalProperties": false,
  "required": ["layout", "style", "title", "summary", "modules"],
  "properties": {
    "layout": {
      "type": "string",
      "enum": ["conclusion-first", "problem-breakdown"]
    },
    "style": {
      "type": "string",
      "enum": ["professional-blue", "dark-emphasis", "warm-editorial"]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    },
    "subtitle": {
      "type": "string",
      "maxLength": 48
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 90
    },
    "summaryLabel": {
      "type": "string",
      "maxLength": 8
    },
    "modules": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "body"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14
          },
          "body": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 24
            }
          },
          "tag": {
            "type": "string",
            "maxLength": 8
          }
        }
      }
    },
    "footer": {
      "type": "string",
      "maxLength": 80
    }
  }
}
