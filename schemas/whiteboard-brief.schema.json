{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Structured Feishu Whiteboard Brief",
  "type": "object",
  "additionalProperties": false,
  "required": ["layout", "style", "title", "summary"],
  "properties": {
    "layout": {
      "type": "string",
      "enum": ["conclusion-first", "problem-breakdown", "large-canvas", "roadmap", "process-chain", "comparison-matrix"]
    },
    "style": {
      "type": "string",
      "enum": ["professional-blue", "dark-emphasis", "warm-editorial", "feishu-neutral", "feishu-status", "feishu-decision-dark", "apple-studio", "linear-command"]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    },
    "subtitle": {
      "type": "string",
      "maxLength": 48
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 90
    },
    "summaryLabel": {
      "type": "string",
      "maxLength": 8
    },
    "modules": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "body"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14
          },
          "body": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 24
            }
          },
          "tag": {
            "type": "string",
            "maxLength": 8
          },
          "metric": {
            "type": "string",
            "maxLength": 18,
            "description": "Optional single card-level metric. Do not repeat the same metric in another section; this schema has no separate footer metric area."
          },
          "metricKey": {
            "type": "string",
            "maxLength": 16,
            "pattern": "^[A-Za-z][A-Za-z0-9-]*$",
            "description": "Optional semantic metric key used to prevent duplicate metrics, such as coverage, efficiency, risk, cost, case, or quality."
          }
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 3,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "title"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["overview", "background", "modules", "roadmap", "metrics-evidence", "risks", "actions"]
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 18
          },
          "summary": {
            "type": "string",
            "maxLength": 70
          },
          "items": {
            "type": "array",
            "maxItems": 4,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["title", "body"],
              "properties": {
                "title": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 14
                },
                "body": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 3,
                  "items": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 24
                  }
                }
              }
            }
          },
          "metrics": {
            "type": "array",
            "maxItems": 4,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 20
            }
          },
          "risks": {
            "type": "array",
            "maxItems": 4,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 28
            }
          },
          "actions": {
            "type": "array",
            "maxItems": 4,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 28
            }
          }
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "body"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14
          },
          "body": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 24
            }
          },
          "tag": {
            "type": "string",
            "maxLength": 8
          }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 4,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "body"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 12
          },
          "body": {
            "type": "array",
            "minItems": 1,
            "maxItems": 2,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 22
            }
          },
          "input": {
            "type": "string",
            "maxLength": 14
          },
          "output": {
            "type": "string",
            "maxLength": 14
          }
        }
      }
    },
    "matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columns", "rows"],
      "properties": {
        "columns": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 10
          }
        },
        "rows": {
          "type": "array",
          "minItems": 3,
          "maxItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "cells"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 14
              },
              "cells": {
                "type": "array",
                "minItems": 3,
                "maxItems": 5,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 14
                }
              },
              "recommended": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "footer": {
      "type": "string",
      "maxLength": 80
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "layout": {
            "const": "large-canvas"
          }
        }
      },
      "then": {
        "required": ["sections"]
      },
      "else": {
        "if": {
          "properties": {
            "layout": {
              "const": "roadmap"
            }
          }
        },
        "then": {
          "required": ["stages"]
        },
        "else": {
          "if": {
            "properties": {
              "layout": {
                "const": "process-chain"
              }
            }
          },
          "then": {
            "required": ["nodes"]
          },
          "else": {
            "if": {
              "properties": {
                "layout": {
                  "const": "comparison-matrix"
                }
              }
            },
            "then": {
              "required": ["matrix"]
            },
            "else": {
              "required": ["modules"]
            }
          }
        }
      }
    }
  ]
}
