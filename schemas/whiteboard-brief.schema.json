{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Structured Feishu Whiteboard Brief",
  "type": "object",
  "additionalProperties": false,
  "required": ["layout", "style", "title", "summary"],
  "properties": {
    "layout": {
      "type": "string",
      "enum": ["conclusion-first", "problem-breakdown", "large-canvas", "roadmap", "process-chain", "comparison-matrix", "milestone-timeline", "funnel", "pyramid", "metric-dashboard", "progress-wall", "ranked-bars", "variance-bridge", "expression-canvas"]
    },
    "renderTarget": {
      "type": "string",
      "enum": ["svg", "dsl"],
      "description": "Optional renderer target. SVG remains the default for report templates; DSL is used for V3.2 controlled expressive scenes."
    },
    "style": {
      "type": "string",
      "enum": ["professional-blue", "dark-emphasis", "warm-editorial", "feishu-neutral", "feishu-status", "feishu-decision-dark", "apple-studio", "linear-command"]
    },
    "expressionMode": {
      "type": "string",
      "enum": ["dashboard-onepage", "narrative-map", "modular-canvas"]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    },
    "subtitle": {
      "type": "string",
      "maxLength": 48
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 90
    },
    "summaryLabel": {
      "type": "string",
      "maxLength": 8
    },
    "modules": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "body"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14
          },
          "body": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 24
            }
          },
          "tag": {
            "type": "string",
            "maxLength": 8
          },
          "metric": {
            "type": "string",
            "maxLength": 18,
            "description": "Optional single card-level metric. Do not repeat the same metric in another section; this schema has no separate footer metric area."
          },
          "metricKey": {
            "type": "string",
            "maxLength": 16,
            "pattern": "^[A-Za-z][A-Za-z0-9-]*$",
            "description": "Optional semantic metric key used to prevent duplicate metrics, such as coverage, efficiency, risk, cost, case, or quality."
          }
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 3,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "title"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["overview", "background", "modules", "roadmap", "metrics-evidence", "risks", "actions"]
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 18
          },
          "summary": {
            "type": "string",
            "maxLength": 70
          },
          "items": {
            "type": "array",
            "maxItems": 4,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["title", "body"],
              "properties": {
                "title": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 14
                },
                "body": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 3,
                  "items": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 24
                  }
                }
              }
            }
          },
          "metrics": {
            "type": "array",
            "maxItems": 4,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 20
            }
          },
          "risks": {
            "type": "array",
            "maxItems": 4,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 28
            }
          },
          "actions": {
            "type": "array",
            "maxItems": 4,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 28
            }
          }
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "body"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14
          },
          "body": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 24
            }
          },
          "tag": {
            "type": "string",
            "maxLength": 8
          }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 4,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "body"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 12
          },
          "body": {
            "type": "array",
            "minItems": 1,
            "maxItems": 2,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 22
            }
          },
          "input": {
            "type": "string",
            "maxLength": 14
          },
          "output": {
            "type": "string",
            "maxLength": 14
          }
        }
      }
    },
    "matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columns", "rows"],
      "properties": {
        "columns": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 10
          }
        },
        "rows": {
          "type": "array",
          "minItems": 3,
          "maxItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "cells"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 14
              },
              "cells": {
                "type": "array",
                "minItems": 3,
                "maxItems": 5,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 14
                }
              },
              "recommended": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "timeline": {
      "type": "array",
      "minItems": 3,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "title", "body"],
        "properties": {
          "date": {
            "type": "string",
            "minLength": 1,
            "maxLength": 10
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14
          },
          "body": {
            "type": "string",
            "minLength": 1,
            "maxLength": 32
          }
        }
      }
    },
    "funnelStages": {
      "type": "array",
      "minItems": 3,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "value"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14
          },
          "value": {
            "type": "string",
            "minLength": 1,
            "maxLength": 10
          },
          "note": {
            "type": "string",
            "maxLength": 30
          }
        }
      }
    },
    "layers": {
      "type": "array",
      "minItems": 3,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14
          },
          "body": {
            "type": "string",
            "maxLength": 28
          }
        }
      }
    },
    "metricCards": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "value"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14
          },
          "value": {
            "type": "string",
            "minLength": 1,
            "maxLength": 12
          },
          "delta": {
            "type": "string",
            "maxLength": 18
          },
          "note": {
            "type": "string",
            "maxLength": 24
          },
          "status": {
            "type": "string",
            "enum": ["good", "neutral", "risk"]
          }
        }
      }
    },
    "progressBars": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "value"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14
          },
          "value": {
            "type": "string",
            "minLength": 1,
            "maxLength": 10
          },
          "note": {
            "type": "string",
            "maxLength": 24
          }
        }
      }
    },
    "rankedBars": {
      "type": "array",
      "minItems": 3,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "value"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14
          },
          "value": {
            "type": "string",
            "minLength": 1,
            "maxLength": 10
          },
          "note": {
            "type": "string",
            "maxLength": 30
          },
          "status": {
            "type": "string",
            "enum": ["good", "neutral", "risk"]
          }
        }
      }
    },
    "bridgeSteps": {
      "type": "array",
      "minItems": 4,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "value", "type"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14
          },
          "value": {
            "type": "string",
            "minLength": 1,
            "maxLength": 12
          },
          "type": {
            "type": "string",
            "enum": ["start", "increase", "decrease", "end"]
          },
          "note": {
            "type": "string",
            "maxLength": 28
          }
        }
      }
    },
    "expressionBlocks": {
      "type": "array",
      "minItems": 4,
      "maxItems": 9,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "title"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["statement", "metric-card", "progress-bar", "ranked-bar", "risk-list", "action-list", "evidence-list", "narrative-chain", "mini-roadmap", "comparison-summary", "status-board", "trend-sparkline", "decision-matrix", "variance-bridge-v2"]
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 18
          },
          "body": {
            "type": "array",
            "maxItems": 4,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 30
            }
          },
          "value": {
            "type": "string",
            "maxLength": 12
          },
          "label": {
            "type": "string",
            "maxLength": 12
          },
          "note": {
            "type": "string",
            "maxLength": 28
          },
          "status": {
            "type": "string",
            "enum": ["good", "neutral", "risk"]
          },
          "items": {
            "type": "array",
            "maxItems": 5,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label"],
              "properties": {
                "label": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 16
                },
                "value": {
                  "type": "string",
                  "maxLength": 12
                },
                "note": {
                  "type": "string",
                  "maxLength": 24
                },
                "status": {
                  "type": "string",
                  "enum": ["good", "neutral", "risk"]
                }
              }
            }
          }
        }
      }
    },
    "insight": {
      "type": "string",
      "maxLength": 90
    },
    "footer": {
      "type": "string",
      "maxLength": 80
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "layout": {
            "const": "expression-canvas"
          }
        }
      },
      "then": {
        "required": ["expressionMode", "expressionBlocks"]
      },
      "else": {
        "if": {
          "properties": {
            "layout": {
              "const": "large-canvas"
            }
          }
        },
        "then": {
          "required": ["sections"]
        },
        "else": {
          "if": {
            "properties": {
              "layout": {
                "const": "roadmap"
              }
            }
          },
          "then": {
            "required": ["stages"]
          },
          "else": {
            "if": {
              "properties": {
                "layout": {
                  "const": "process-chain"
                }
              }
            },
            "then": {
              "required": ["nodes"]
            },
            "else": {
              "if": {
                "properties": {
                  "layout": {
                    "const": "comparison-matrix"
                  }
                }
              },
              "then": {
                "required": ["matrix"]
              },
              "else": {
                "if": {
                  "properties": {
                    "layout": {
                      "const": "milestone-timeline"
                    }
                  }
                },
                "then": {
                  "required": ["timeline"]
                },
                "else": {
                  "if": {
                    "properties": {
                      "layout": {
                        "const": "funnel"
                      }
                    }
                  },
                  "then": {
                    "required": ["funnelStages"]
                  },
                  "else": {
                    "if": {
                      "properties": {
                        "layout": {
                          "const": "pyramid"
                        }
                      }
                    },
                    "then": {
                      "required": ["layers"]
                    },
                    "else": {
                      "if": {
                        "properties": {
                          "layout": {
                            "const": "metric-dashboard"
                          }
                        }
                      },
                      "then": {
                        "required": ["metricCards", "progressBars"]
                      },
                      "else": {
                        "if": {
                          "properties": {
                            "layout": {
                              "const": "progress-wall"
                            }
                          }
                        },
                        "then": {
                          "required": ["progressBars"]
                        },
                        "else": {
                          "if": {
                            "properties": {
                              "layout": {
                                "const": "ranked-bars"
                              }
                            }
                          },
                          "then": {
                            "required": ["rankedBars"]
                          },
                          "else": {
                            "if": {
                              "properties": {
                                "layout": {
                                  "const": "variance-bridge"
                                }
                              }
                            },
                            "then": {
                              "required": ["bridgeSteps"]
                            },
                            "else": {
                              "required": ["modules"]
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
