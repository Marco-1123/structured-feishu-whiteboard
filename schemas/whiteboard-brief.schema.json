{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Structured Feishu Whiteboard Brief",
  "type": "object",
  "additionalProperties": false,
  "required": ["layout", "style", "title", "summary", "modules"],
  "properties": {
    "layout": {
      "type": "string",
      "enum": ["conclusion-first", "problem-breakdown"]
    },
    "style": {
      "type": "string",
      "enum": ["professional-blue", "dark-emphasis", "warm-editorial"]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    },
    "subtitle": {
      "type": "string",
      "maxLength": 48
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 90
    },
    "summaryLabel": {
      "type": "string",
      "maxLength": 8
    },
    "modules": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "body"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14
          },
          "body": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 24
            }
          },
          "tag": {
            "type": "string",
            "maxLength": 8
          },
          "metric": {
            "type": "string",
            "maxLength": 18,
            "description": "Optional single card-level metric. Do not repeat the same metric in another section; this schema has no separate footer metric area."
          },
          "metricKey": {
            "type": "string",
            "maxLength": 16,
            "pattern": "^[A-Za-z][A-Za-z0-9-]*$",
            "description": "Optional semantic metric key used to prevent duplicate metrics, such as coverage, efficiency, risk, cost, case, or quality."
          }
        }
      }
    },
    "footer": {
      "type": "string",
      "maxLength": 80
    }
  }
}
