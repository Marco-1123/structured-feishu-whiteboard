{
  "layout": "process-chain",
  "style": "feishu-status",
  "title": "审批异常排查闭环",
  "subtitle": "让异常从发现、定位、处理到复盘形成标准链路。",
  "summaryLabel": "流程目标",
  "summary": "把分散排查动作收敛成一条可追踪链路，减少人工切换和重复沟通。",
  "nodes": [
    {
      "title": "触发",
      "body": ["用户反馈审批卡住", "系统记录异常入口"],
      "input": "审批实例",
      "output": "异常工单"
    },
    {
      "title": "定位",
      "body": ["读取节点与权限状态", "识别失败环节"],
      "input": "流程日志",
      "output": "失败原因"
    },
    {
      "title": "处理",
      "body": ["补齐权限或重试节点", "必要时进入人工审批"],
      "input": "处置方案",
      "output": "恢复结果"
    },
    {
      "title": "复盘",
      "body": ["沉淀异常类型", "更新监控和提示文案"],
      "input": "案例记录",
      "output": "规则优化"
    }
  ],
  "footer": "判断标准：同类异常下次应能自动定位，并给出明确处置建议。"
}
